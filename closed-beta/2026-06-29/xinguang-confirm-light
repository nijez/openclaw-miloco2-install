#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_CONFIRM_LIGHT_VERSION="2026-06-30.1"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
PENDING_FILE="$BASE_DIR/pending-light-request.json"
PERMIT_FILE="$BASE_DIR/l6b-execute-permit.json"
TARGET_NAME="门市 / 馨光RGBCW幻彩灯柱2"

direct_reply_begin() {
  printf '<!-- XINGUANG_DIRECT_REPLY_BEGIN copy-exactly -->\n'
}

direct_reply_end() {
  printf '<!-- XINGUANG_DIRECT_REPLY_END -->\n'
}

extract_request_id() {
  local text="$*"
  printf '%s\n' "$text" | grep -Eo 'xg-preview-[0-9]{14}-[0-9]{4}' | head -n 1 || true
}

main() {
  local request_id
  request_id="$(extract_request_id "$@")"

  direct_reply_begin
  if [[ -z "$request_id" ]]; then
    printf '确认编号不完整，未执行。\n'
    printf '请使用预览里的完整确认编号。\n'
    direct_reply_end
    return 0
  fi

  mkdir -p "$BASE_DIR"
  python3 - "$PENDING_FILE" "$PERMIT_FILE" "$request_id" "$TARGET_NAME" <<'PY'
import datetime, json, os, sys

pending_path, permit_path, request_id, target_name = sys.argv[1:5]
now = datetime.datetime.now().astimezone()

def fail(message):
    print(message)
    raise SystemExit(0)

try:
    with open(pending_path, "r", encoding="utf-8") as f:
        pending = json.load(f)
except Exception:
    fail("没有找到待确认的灯光预览，未执行。")

if pending.get("request_id") != request_id:
    fail("确认编号不匹配，未执行。")

if pending.get("target") != target_name:
    fail("目标设备不匹配，未执行。")

if pending.get("scope") != "single_device_only":
    fail("控制范围不安全，未执行。")

if pending.get("status") != "pending_preview":
    fail("当前预览状态不可确认，未执行。")

if pending.get("executed") is True:
    fail("该确认编号已经执行过，未重复执行。")

try:
    expires = datetime.datetime.fromisoformat(str(pending.get("expires_at", "")))
except Exception:
    fail("灯光预览已失效，未执行。")

if expires < now:
    fail("灯光预览已过期，未执行。")

execute_expires = now + datetime.timedelta(seconds=120)
pending["confirmed"] = True
pending["confirmed_at"] = now.isoformat()
pending["execute_expires_at"] = execute_expires.isoformat()
pending["status"] = "confirmed_ready"
pending.setdefault("restored", False)
pending.setdefault("restored_at", None)
pending.setdefault("executed_at", None)

with open(pending_path, "w", encoding="utf-8") as f:
    json.dump(pending, f, ensure_ascii=False, indent=2)
    f.write("\n")

permit = {
    "request_id": request_id,
    "target": target_name,
    "action": "execute",
    "created_at": now.isoformat(),
    "expires_at": execute_expires.isoformat(),
    "used": False,
}
with open(permit_path, "w", encoding="utf-8") as f:
    json.dump(permit, f, ensure_ascii=False, indent=2)
    f.write("\n")
try:
    os.chmod(permit_path, 0o600)
except Exception:
    pass

print("已确认本次 L6-B 测试边界。")
print(f"确认编号：{request_id}")
print("目标：门市 / 馨光RGBCW幻彩灯柱2")
print("范围：只控制这一台")
print("状态：已确认，尚未执行")
print("请在 2 分钟内发送：")
print(f"执行 {request_id}，把门市灯柱调成低亮度暖色，只调这一台")
PY
  direct_reply_end
}

main "$@"
