#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_LOCK_TARGET_DEVICE_VERSION="2026-07-01.1"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
INSTALL_DIR="${INSTALL_DIR:-$HOME/wainfort-light}"
ENV_PRIMARY="/etc/xinguang-wainfort.env"
ENV_FALLBACK="$INSTALL_DIR/.env"
LOCK_FILE="$BASE_DIR/target-device-lock.json"
TARGET_LABEL="门市 / 馨光RGBCW幻彩灯柱2"
TARGET_ROOM="门市"
TARGET_DEVICE_NAME="馨光RGBCW幻彩灯柱2"
API_PORT="${WAINFORT_API_PORT:-1888}"
API_TOKEN="${WAINFORT_API_TOKEN:-}"

load_env() {
  local env_file=""
  if [[ -r "$ENV_PRIMARY" ]]; then
    env_file="$ENV_PRIMARY"
  elif [[ -r "$ENV_FALLBACK" ]]; then
    env_file="$ENV_FALLBACK"
  fi
  if [[ -n "$env_file" ]]; then
    API_TOKEN="$(grep -E '^WAINFORT_API_TOKEN=' "$env_file" 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
    API_PORT="$(grep -E '^WAINFORT_API_PORT=' "$env_file" 2>/dev/null | tail -n 1 | cut -d= -f2- || true)"
  fi
  API_PORT="${API_PORT:-1888}"
}

main() {
  load_env
  local devices_file selected_index
  devices_file="$(mktemp "${TMPDIR:-/tmp}/xinguang-devices.XXXXXX")"
  trap "rm -f '$devices_file'" EXIT

  if [[ -n "${XINGUANG_DEVICES_FILE:-}" && -r "${XINGUANG_DEVICES_FILE:-}" ]]; then
    cp "$XINGUANG_DEVICES_FILE" "$devices_file"
  else
    if [[ -z "$API_TOKEN" ]]; then
      printf '无法读取灯光服务配置，未锁定目标设备。\n' >&2
      return 1
    fi
    local code
    code="$(curl -sS --max-time 8 -o "$devices_file" -w '%{http_code}' \
      -H "Authorization: Bearer $API_TOKEN" \
      "http://127.0.0.1:$API_PORT/api/devices" 2>/dev/null || true)"
    if [[ "$code" != "200" ]]; then
      printf '无法读取设备列表，未锁定目标设备。\n' >&2
      return 1
    fi
  fi

  selected_index="${1:-}"
  mkdir -p "$BASE_DIR"
  python3 - "$devices_file" "$LOCK_FILE" "$TARGET_LABEL" "$TARGET_ROOM" "$TARGET_DEVICE_NAME" "$selected_index" <<'PY'
import datetime, json, os, sys

devices_path, lock_path, target_label, target_room, target_name, selected_index = sys.argv[1:7]

def flatten(node):
    if isinstance(node, dict):
        yield node
        for value in node.values():
            yield from flatten(value)
    elif isinstance(node, list):
        for item in node:
            yield from flatten(item)

def pick(obj, keys):
    for key in keys:
        if key in obj and obj[key] not in (None, ""):
            value = obj[key]
            if isinstance(value, (dict, list)):
                continue
            return str(value)
    return ""

def bool_online(obj):
    raw = None
    for key in ("online", "is_online", "isOnline", "reachable", "connected", "status", "state"):
        if key in obj and obj[key] not in (None, ""):
            raw = obj[key]
            break
    if isinstance(raw, bool):
        return raw
    text = str(raw or "").strip().lower()
    if text in ("true", "1", "online", "running", "connected", "available", "active", "正常"):
        return True
    if text in ("false", "0", "offline", "stopped", "disconnected", "unavailable", "inactive", "离线"):
        return False
    return None

def is_light(obj):
    text = " ".join(
        pick(obj, keys)
        for keys in (
            ("type", "device_type", "deviceType", "category", "category_name"),
            ("model", "model_name", "modelName", "miot_type"),
            ("product", "product_name", "productName"),
            ("name", "device_name", "deviceName"),
        )
    ).lower()
    return any(word in text for word in ("light", "lamp", "rgbcw", "灯", "灯柱", "灯带", "wainft.light.rgbcwy"))

try:
    with open(devices_path, "r", encoding="utf-8") as f:
        payload = json.load(f)
except Exception:
    print("设备列表无法解析，未锁定目标设备。", file=sys.stderr)
    raise SystemExit(1)

candidates = []
for obj in flatten(payload):
    device_id = pick(obj, ("device_id", "deviceId", "did", "id", "miot_did"))
    name = pick(obj, ("name", "device_name", "deviceName", "display_name", "displayName"))
    room = pick(obj, ("room", "room_name", "roomName", "area", "area_name"))
    label = f"{room} / {name}" if room and name else pick(obj, ("target_label", "label"))
    if not device_id:
        continue
    if label == target_label or (room == target_room and name == target_name):
        candidates.append({
            "raw": obj,
            "device_id": device_id,
            "name": name,
            "room": room,
            "label": label or target_label,
            "model": pick(obj, ("model", "model_name", "modelName", "miot_type")),
            "type": pick(obj, ("type", "device_type", "deviceType", "category", "category_name")),
            "product": pick(obj, ("product", "product_name", "productName")),
            "online": bool_online(obj),
            "is_light": is_light(obj),
        })

if not candidates:
    print("未找到唯一的门市灯柱候选设备，未锁定。", file=sys.stderr)
    raise SystemExit(1)

if selected_index:
    try:
        idx = int(selected_index) - 1
        candidates = [candidates[idx]]
    except Exception:
        print("候选序号无效，未锁定。", file=sys.stderr)
        raise SystemExit(1)

if len(candidates) > 1:
    print("找到多个候选设备，请工作人员确认后用序号锁定：", file=sys.stderr)
    for i, c in enumerate(candidates, 1):
        print(f"{i}. {c['label']} 设备ID后四位：{c['device_id'][-4:]}", file=sys.stderr)
    raise SystemExit(1)

candidate = candidates[0]
if candidate["online"] is not True:
    print("目标设备当前不在线，未锁定。", file=sys.stderr)
    raise SystemExit(1)
if not candidate["is_light"]:
    print("目标设备类型不是灯光设备，未锁定。", file=sys.stderr)
    raise SystemExit(1)

suffix = candidate["device_id"][-4:]
phrase = f"锁定门市灯柱 {suffix}"
print(f"准备锁定目标：{candidate['label']}")
print(f"设备ID后四位：{suffix}")
print(f"请在终端输入确认短语：{phrase}")
typed = os.environ.get("XINGUANG_TARGET_DEVICE_CONFIRM", "").strip()
if not typed:
    try:
        with open("/dev/tty", "r", encoding="utf-8", errors="replace") as tty:
            print("> ", end="", flush=True)
            typed = tty.readline().strip()
    except Exception:
        print("未读取到工作人员确认短语，未锁定。", file=sys.stderr)
        raise SystemExit(1)
if typed != phrase:
    print("确认短语不匹配，未锁定。", file=sys.stderr)
    raise SystemExit(1)

lock = {
    "version": "2026-07-01.1",
    "created_at": datetime.datetime.now().astimezone().isoformat(),
    "target_label": target_label,
    "room": candidate["room"],
    "device_name": candidate["name"],
    "device_id": candidate["device_id"],
    "model": candidate["model"],
    "type": candidate["type"],
    "product": candidate["product"],
    "online": True,
    "source": "xinguang-lock-target-device",
}
os.makedirs(os.path.dirname(lock_path), exist_ok=True)
with open(lock_path, "w", encoding="utf-8") as f:
    json.dump(lock, f, ensure_ascii=False, indent=2)
    f.write("\n")
try:
    os.chmod(lock_path, 0o600)
except Exception:
    pass
print("目标设备已锁定。")
print(f"目标：{target_label}")
print(f"设备ID后四位：{suffix}")
print("未执行真实灯光控制。")
PY
}

main "$@"
