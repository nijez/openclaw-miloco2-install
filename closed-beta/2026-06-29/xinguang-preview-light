#!/usr/bin/env bash
set -Eeuo pipefail

XINGUANG_PREVIEW_LIGHT_VERSION="2026-06-30.2"
BASE_DIR="${XINGUANG_BASE_DIR:-$HOME/xinguang-ai-light}"
PENDING_FILE="$BASE_DIR/pending-light-request.json"
REQUEST_TTL_SECONDS="${XINGUANG_PREVIEW_TTL_SECONDS:-300}"

direct_reply_begin() {
  printf '<!-- XINGUANG_DIRECT_REPLY_BEGIN copy-exactly -->\n'
}

direct_reply_end() {
  printf '<!-- XINGUANG_DIRECT_REPLY_END -->\n'
}

trim() {
  local s="$1"
  s="${s//$'\n'/ }"
  s="${s//$'\r'/ }"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

contains_broad_scope() {
  local text="$1"
  [[ "$text" =~ (全屋|全店|所有|全部|整屋|整店|一楼|二楼|客厅|卧室|茶室|灯带|软膜|筒灯|灯组|所有灯|全部灯) ]]
}

contains_target() {
  local text="$1"
  [[ "$text" =~ (门市[[:space:]]*的?[[:space:]]*灯柱|馨光RGBCW幻彩灯柱2) ]]
}

effect_name() {
  local text="$1"
  if [[ "$text" =~ (恢复|白光|接近白光) ]]; then
    printf '接近白光'
  elif [[ "$text" =~ (马尔代夫|海边|日落) ]]; then
    printf '马尔代夫海边日落'
  elif [[ "$text" =~ (森林|晨光) ]]; then
    printf '森林晨光'
  elif [[ "$text" =~ (暖|暖色) ]]; then
    printf '低亮度暖色'
  else
    printf '按你的描述生成灯光效果'
  fi
}

new_request_id() {
  printf 'xg-preview-%s-%04d' "$(date +%Y%m%d%H%M%S)" "$((RANDOM % 10000))"
}

write_pending() {
  local request_id="$1" original="$2" effect="$3"
  mkdir -p "$BASE_DIR"
  python3 - "$PENDING_FILE" "$request_id" "$original" "$effect" "$REQUEST_TTL_SECONDS" <<'PY'
import datetime, json, os, sys

path, request_id, original, effect, ttl = sys.argv[1:6]
now = datetime.datetime.now().astimezone()
expires = now + datetime.timedelta(seconds=int(ttl))
entry = {
    "request_id": request_id,
    "created_at": now.isoformat(),
    "expires_at": expires.isoformat(),
    "status": "pending_preview",
    "target": "门市 / 馨光RGBCW幻彩灯柱2",
    "scope": "single_device_only",
    "effect": effect,
    "original_text": original,
    "confirmed": False,
    "executed": False,
}
os.makedirs(os.path.dirname(path), exist_ok=True)
with open(path, "w", encoding="utf-8") as f:
    json.dump(entry, f, ensure_ascii=False, indent=2)
    f.write("\n")
PY
}

confirm_request() {
  local request_id="$1"
  direct_reply_begin
  if [[ -z "$request_id" ]]; then
    printf '确认信息不完整，未执行。\n'
    printf '请使用预览里的完整确认语。\n'
    direct_reply_end
    return 0
  fi
  if [[ ! -f "$PENDING_FILE" ]]; then
    printf '没有找到待确认的灯光预览，未执行。\n'
    direct_reply_end
    return 0
  fi
  python3 - "$PENDING_FILE" "$request_id" <<'PY'
import datetime, json, sys

path, request_id = sys.argv[1:3]
try:
    with open(path, "r", encoding="utf-8") as f:
        pending = json.load(f)
except Exception:
    print("没有找到待确认的灯光预览，未执行。")
    sys.exit(0)

if pending.get("request_id") != request_id:
    print("确认编号不匹配，未执行。")
    sys.exit(0)

try:
    expires = datetime.datetime.fromisoformat(pending.get("expires_at", ""))
except Exception:
    print("灯光预览已失效，未执行。")
    sys.exit(0)

now = datetime.datetime.now().astimezone()
if expires < now:
    print("灯光预览已过期，未执行。")
    sys.exit(0)

print("已收到确认。")
print("当前仍处于安全预览验收阶段，暂不执行真实灯光控制。")
PY
  direct_reply_end
}

main() {
  local raw text effect request_id confirm_id
  raw="${*:-}"
  text="$(trim "$raw")"

  if [[ "$text" =~ ^确认执行[[:space:]]+([^[:space:]，,]+)[，,][[:space:]]*只控制门市灯柱这一台$ ]]; then
    confirm_id="${BASH_REMATCH[1]}"
    confirm_request "$confirm_id"
    return 0
  fi

  if [[ "$text" == "确认执行，只控制门市灯柱这一台" || "$text" == "确认执行 只控制门市灯柱这一台" ]]; then
    confirm_request ""
    return 0
  fi

  if [[ -z "$text" ]]; then
    direct_reply_begin
    printf '请先说出要测试的灯光效果。\n'
    printf '例如：门市灯柱来个低亮度暖色。\n'
    direct_reply_end
    return 0
  fi

  if contains_broad_scope "$text" && ! contains_target "$text"; then
    direct_reply_begin
    printf '为避免误控，请先明确目标设备。\n'
    printf '请这样说：门市灯柱来个低亮度暖色。\n'
    printf '当前状态：尚未执行。\n'
    direct_reply_end
    return 0
  fi

  if ! contains_target "$text"; then
    direct_reply_begin
    printf '为避免误控，请先明确目标设备。\n'
    printf '请这样说：门市灯柱来个低亮度暖色。\n'
    printf '当前状态：尚未执行。\n'
    direct_reply_end
    return 0
  fi

  effect="$(effect_name "$text")"
  request_id="$(new_request_id)"
  write_pending "$request_id" "$text" "$effect"

  direct_reply_begin
  printf '我理解你的需求如下：\n\n'
  printf '确认编号：%s\n' "$request_id"
  printf '目标：门市 / 馨光RGBCW幻彩灯柱2\n'
  printf '范围：只控制这一台\n'
  printf '灯光效果：%s\n' "$effect"
  printf '不会影响：软膜、筒灯、灯带、其他门市灯、全店灯光\n'
  printf '当前状态：尚未执行\n\n'
  printf '如确认，请回复：\n'
  printf '确认执行 %s，只控制门市灯柱这一台\n' "$request_id"
  direct_reply_end
}

main "$@"
